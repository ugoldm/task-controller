# Скопируйте в .env и заполните.

# Пароль на вход (обязательно для защиты данных).
APP_PASSWORD=change-this-to-real-password

# Секрет для подписи cookie-сессии (любая длинная случайная строка).
SESSION_SECRET=please-change-this-to-a-long-random-string

# Порт (по умолчанию 3000).
PORT=3000

# --- AI-функции (опционально) ---
# Если ключ не задан, разбор текста работает на простой эвристике, без обращения к Claude.
ANTHROPIC_API_KEY=
# Модель для разбора задач. По умолчанию claude-opus-4-8.
ANTHROPIC_MODEL=claude-opus-4-8

# --- Деплой через Docker + Caddy (нужно только на сервере) ---
# Домен, на котором будет работать приложение (A-запись должна указывать на IP сервера).
DOMAIN=tasks.example.com
# Email для Let's Encrypt (необязательно, но желательно — туда придут уведомления о сертификате).
CADDY_EMAIL=
